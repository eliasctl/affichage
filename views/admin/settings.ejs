<%- include('_header', { currentPath: '/admin/settings' }) %>

<%# ── Token d'accès écran ── %>
<div class="card">
  <div class="card-title">
    <span>Accès écrans (token)</span>
    <span style="font-size:.78rem;color:#bbb;font-weight:400">
      Empêche l'accès public à l'affichage
    </span>
  </div>
  <p style="font-size:.85rem;color:#666;margin-bottom:.9rem;line-height:1.5">
    Les écrans (Pi en kiosque) ouvrent une URL contenant ce token.
    Une fois le token validé, un cookie longue durée (≈ 10 ans) est posé : <strong>l'écran ne se déconnecte plus jamais</strong>.
    Régénérer le token déconnecte tous les écrans : il faudra les reconfigurer.
  </p>

  <label>URL à ouvrir sur un nouvel écran</label>
  <div style="display:flex;gap:.5rem;margin-bottom:1rem">
    <input type="text" id="display-url" readonly
           value="<%= '/?lite&token=' + display_token %>"
           style="flex:1;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:.82rem;background:#fafafa">
    <button type="button" class="btn btn-gray" id="copy-url">📋 Copier</button>
  </div>

  <label>Token brut</label>
  <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
    <code id="display-token"
          style="flex:1;min-width:240px;padding:.55rem .8rem;background:#fafafa;border:1.5px solid #eee;border-radius:6px;font-size:.82rem;word-break:break-all">
      <%= display_token %>
    </code>
    <% if (display_token_locked) { %>
      <span class="badge badge-off" title="Le token est défini par la variable d'environnement DISPLAY_TOKEN">
        🔒 Verrouillé (env)
      </span>
    <% } else { %>
      <form method="post" action="/admin/regen-display-token" style="margin:0"
            onsubmit="return confirm('Régénérer le token va déconnecter TOUS les écrans déjà configurés. Continuer ?')">
        <button type="submit" class="btn btn-danger">🔄 Régénérer</button>
      </form>
    <% } %>
  </div>
</div>

<script>
  document.getElementById('copy-url').addEventListener('click', () => {
    const inp = document.getElementById('display-url');
    const fullUrl = location.origin + inp.value;
    navigator.clipboard.writeText(fullUrl).then(() => {
      const b = document.getElementById('copy-url');
      const old = b.textContent;
      b.textContent = '✓ Copié';
      setTimeout(() => (b.textContent = old), 1500);
    });
  });
  // Affiche l'URL complète dans le champ pour clarté
  (() => {
    const inp = document.getElementById('display-url');
    inp.value = location.origin + inp.value;
  })();
</script>

<%# ── Nom du CI ── %>
<div class="card">
  <div class="card-title">Informations du centre</div>
  <form method="post">
    <input type="hidden" name="action" value="save_ci">
    <div class="form-group">
      <label for="ci_name">Nom du CIS affiché en pied de page</label>
      <input type="text" id="ci_name" name="ci_name"
             value="<%= ci_name %>" placeholder="Ex : CIS Fontainebleau">
    </div>
    <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
  </form>
</div>

<%# ── Logo ── %>
<div class="card">
  <div class="card-title">Logo</div>
  <form method="post" enctype="multipart/form-data" style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap">
    <input type="hidden" name="action" value="save_logo">
    <img id="logo-preview" src="/static/<%= logo %>" alt="Logo actuel"
         style="height:64px;object-fit:contain;background:#f5f5f5;border-radius:6px;padding:6px;border:1.5px solid #eee">
    <div style="flex:1;min-width:200px">
      <label for="logo_file">Remplacer le logo</label>
      <input type="file" id="logo_file" name="logo_file" accept="image/*" required
             style="width:100%;padding:.5rem .7rem;border:1.5px solid #ddd;border-radius:6px;font-size:.85rem">
    </div>
    <button type="submit" class="btn btn-primary" style="flex-shrink:0;margin-bottom:0">
      💾 Enregistrer
    </button>
  </form>
</div>

<%# ── Icônes ── %>
<div class="card">
  <div class="card-title">
    <span>Icônes de spécialités</span>
    <span style="font-size:.78rem;color:#bbb;font-weight:400">
      Affichées dans la colonne gauche de l'écran
    </span>
  </div>

  <%# Icônes existantes %>
  <% if (icons && icons.length) { %>
  <table style="margin-bottom:1.5rem">
    <thead>
      <tr>
        <th style="width:56px">Image</th>
        <th>Label</th>
        <th>Ordre</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
    <% icons.forEach((icon) => { %>
    <tr>
      <td>
        <img src="/static/icons/<%= icon.filename %>"
             style="height:44px;width:44px;object-fit:contain;border-radius:4px;background:#f5f5f5;padding:2px">
      </td>
      <td><strong><%= icon.label || '—' %></strong>
          <span style="font-size:.75rem;color:#ccc;display:block"><%= icon.filename %></span>
      </td>
      <td>
        <div class="actions">
          <form method="post" style="display:inline">
            <input type="hidden" name="action" value="move_icon_up">
            <input type="hidden" name="icon_id" value="<%= icon.id %>">
            <button class="btn btn-gray btn-icon" title="Remonter">↑</button>
          </form>
          <form method="post" style="display:inline">
            <input type="hidden" name="action" value="move_icon_down">
            <input type="hidden" name="icon_id" value="<%= icon.id %>">
            <button class="btn btn-gray btn-icon" title="Descendre">↓</button>
          </form>
        </div>
      </td>
      <td>
        <form method="post" style="display:inline"
              onsubmit="return confirm('Supprimer cette icône ?')">
          <input type="hidden" name="action" value="delete_icon">
          <input type="hidden" name="icon_id" value="<%= icon.id %>">
          <button class="btn btn-danger btn-icon">🗑</button>
        </form>
      </td>
    </tr>
    <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <p style="color:#ccc;font-size:.9rem;margin-bottom:1.2rem">
    Aucune icône — ajoute des écussons de spécialités ci-dessous.
  </p>
  <% } %>

  <%# Ajouter une icône %>
  <form method="post" enctype="multipart/form-data"
        style="background:#fafafa;border:1.5px dashed #e0e0e0;border-radius:8px;padding:1.1rem">
    <input type="hidden" name="action" value="add_icon">
    <p style="font-size:.82rem;font-weight:700;color:#666;margin-bottom:.8rem">+ Ajouter une icône</p>
    <div style="display:flex;gap:.7rem;flex-wrap:wrap;align-items:flex-end">
      <div style="flex:1;min-width:160px">
        <label for="icon_file">Fichier image</label>
        <input type="file" id="icon_file" name="icon_file" accept="image/*" required
               style="width:100%;padding:.5rem .7rem;border:1.5px solid #ddd;border-radius:6px;font-size:.85rem">
      </div>
      <div style="flex:1;min-width:120px">
        <label for="icon_label">Label (optionnel)</label>
        <input type="text" id="icon_label" name="icon_label"
               placeholder="Ex : GRIMP" style="padding:.55rem .8rem">
      </div>
      <button type="submit" class="btn btn-primary" style="flex-shrink:0;margin-bottom:0">
        Ajouter
      </button>
    </div>

    <%# Prévisualisation %>
    <div id="icon-preview" style="margin-top:.7rem"></div>
  </form>
</div>

<script>
  document.getElementById('logo_file').addEventListener('change', function() {
    if (this.files[0])
      document.getElementById('logo-preview').src = URL.createObjectURL(this.files[0]);
  });

  document.getElementById('icon_file').addEventListener('change', function() {
    const prev = document.getElementById('icon-preview');
    prev.innerHTML = '';
    if (this.files[0]) {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(this.files[0]);
      img.style.cssText = 'height:52px;border-radius:5px;object-fit:contain;background:#f0f0f0;padding:3px';
      prev.appendChild(img);
    }
  });
</script>

<%- include('_footer') %>
